{
  "name": "plantplanet-page-generator-poc",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run dev -w backend\" \"npm run dev -w frontend\"",
    "build": "npm run build -w backend && npm run build -w frontend",
    "start": "npm run start -w backend",
    "start:public": "powershell -ExecutionPolicy Bypass -File scripts/start-public.ps1",
    "redirect:update": "powershell -ExecutionPolicy Bypass -File scripts/update-redirect-target.ps1",
    "generate:page": "tsx scripts/generate-page.ts",
    "generate:layout": "tsx scripts/generate-layout-page.ts"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
